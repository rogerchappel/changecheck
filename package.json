{
  "name": "changecheck",
  "version": "0.1.0",
  "description": "Local-first release consistency checker for changelogs, package versions, git tags, and release notes.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "changecheck": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "node --test dist/__tests__/*.test.js",
    "smoke": "node dist/cli.js check fixtures/sample-release --format text",
    "release:check": "npm test && npm run build && npm run smoke"
  },
  "keywords": [
    "changelog",
    "release",
    "version",
    "consistency",
    "cli",
    "audit",
    "local-first"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.19",
    "eslint": "^9.39.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
